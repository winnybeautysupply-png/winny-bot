# ═══════════════════════════════════════════════════════════════
# WINNY BEAUTY BOT — Variables de entorno (Twilio WhatsApp API)
# Copia este archivo a `.env` y llena los valores reales.
# NUNCA subas el .env real a GitHub.
# ═══════════════════════════════════════════════════════════════

# ─── Twilio WhatsApp API (de console.twilio.com) ─────────────────
# Account SID (dashboard de Twilio)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# API Key SID + Secret (Keys & Credentials → API keys & tokens → Create API key)
TWILIO_API_KEY_SID=SKxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_API_KEY_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Número de WhatsApp registrado como Sender (con + y código país, SIN "whatsapp:")
TWILIO_WHATSAPP_NUMBER=+18492489801

# ─── Anthropic Claude API ────────────────────────────────────────
# De console.anthropic.com → API Keys
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxx

# Modelo de Claude a usar
CLAUDE_MODEL=claude-sonnet-4-6

# ─── Configuración del negocio ───────────────────────────────────
# Número de Winny para recibir notificaciones (con código país, sin +)
OWNER_PHONE=18293839433

# Nombre del negocio
BUSINESS_NAME=Winny Beauty Supply

# Zona horaria (para horarios de atención)
TZ=America/Santo_Domingo

# Horario de atención (formato 24h)
BUSINESS_HOURS_START=9
BUSINESS_HOURS_END=19

# Días de atención (0=Dom, 1=Lun, ..., 6=Sab)
BUSINESS_DAYS=1,2,3,4,5,6

# ─── Cuentas bancarias (separadas por |) ─────────────────────────
# Formato: BANCO:NUMERO:TITULAR:TIPO_CUENTA
BANK_ACCOUNTS=Banco Popular:123-456789-0:Winny Mercedes:Ahorros

# ─── Servidor ────────────────────────────────────────────────────
PORT=3000

# Nivel de logs (debug, info, warn, error)
LOG_LEVEL=info

# ─── Base de datos ───────────────────────────────────────────────
DB_PATH=./data/winny-bot.db

# Carpeta donde se guardan los comprobantes de pago
RECEIPTS_DIR=./data/comprobantes
